	scanf("%d",&a);
	printf("Enter any number :");
	scanf("%d",&b);
	printf("Enter any number :");
	scanf("%d",&c);

	if(a==b || a==c || b==c)
	{
		printf("All are Equal....");
	}
	else
	{
		if(a<b)
		{

			if(a<c)
			{
				printf("%d is MINIMUM Number....",a);
			}
			else
			{
				printf("%d is MINIMUM Number....",c);
			}
		}
		else
		{
			if(b<c)
			{
